async def _run_background_tasks():
    """Launch periodic background loops with crash-resilient wrappers."""
    async def _loop(coro, interval, name):
        await asyncio.sleep(10)  # let polling stabilize first
        while True:
            try:
                await coro()
            except Exception:
                logger.exception("Background task %s failed", name)
            await asyncio.sleep(interval)

    # asyncio.create_task(_loop(poll_something, 300, "something"))
    pass


@dp.on_started()
async def on_startup():
    """One-time async init after polling starts."""
    await init_db()
    await _run_background_tasks()
    logger.info("Bot started. Polling for updates...")


def main():
    logging.basicConfig(
        format="%(asctime)s - %(name)s - %(levelname)s - %(message)s",
        level=getattr(logging, LOG_LEVEL, logging.INFO),
    )
    _register_handlers()
    asyncio.run(dp.start_polling(bot))


if __name__ == "__main__":
    main()
