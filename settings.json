{
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/skills/learned/_gen-index.sh\"",
            "timeout": 10,
            "statusMessage": "Loading learned-skills index"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "cs",
    "refreshInterval": 1
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  },
  "language": "Russian",
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "theme": "dark-daltonized",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true
}
